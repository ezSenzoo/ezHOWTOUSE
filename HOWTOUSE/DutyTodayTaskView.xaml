<UserControl x:Class="HOWTOUSE.DutyTodayTaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converter="clr-namespace:HOWTOUSE.Converter"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converter:CodeMatchConverter x:Key="CodeMatchConverter"/>
        <Style x:Key="StretchListBoxItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="TitleButton" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0E91F5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SmallActionButton" TargetType="Button">
            <Setter Property="Background" Value="#EFF6FF" />
            <Setter Property="Foreground" Value="#0E91F5" />
            <Setter Property="BorderBrush" Value="#BFDBFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="28" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource Panel}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 제목 -->
                    <TextBlock Text="오늘 확인 업무"
               FontSize="20"
               FontWeight="Bold"
               Foreground="#0F172A"/>
                    <!--<TextBlock
    x:Name="TaskCountTextBlock"
    Margin="0,4,0,0"
    Foreground="#64748B"
    FontSize="12"/>-->

                    <!-- 조회조건 -->
                    <Grid Grid.Row="1"
          Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="업무일자"
                   VerticalAlignment="Center"/>

                        <DatePicker x:Name="SearchTaskDatePicker" Grid.Column="1" Margin="8,0,0,0" 
                                    SelectedDateChanged="SearchTaskDatePicker_SelectedDateChanged"/>

                        <Button Grid.Column="3"
                Width="48"
                Content="추가"
                Style="{StaticResource SmallActionButton}"
                Click="NewTodayTaskButton_Click"/>
                        <!--<CheckBox Grid.Row="1"
          x:Name="IncludeUncompletedCheckBox"
          Margin="0,10,0,0"
          Content="미확인 업무 포함"

         />-->

                    </Grid>


                </Grid>

                <ListBox x:Name="TodayTaskListBox"
                         Grid.Row="2"
                         Margin="0,14,0,0"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource StretchListBoxItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsCompleted, Mode=TwoWay}" VerticalAlignment="Center" 
                                              Click="TaskCompleted_Click"/>
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TRGT_TP_NM}" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#64748B"/>

                                                        <Style.Triggers>

                                                            <!-- 공통업무 -->
                                                            <DataTrigger Binding="{Binding TRGT_TP_CD}" Value="ALL">
                                                                <Setter Property="Foreground" Value="#0E91F5"/>
                                                            </DataTrigger>

                                                            <!-- 개인업무 -->
                                                            <DataTrigger Binding="{Binding TRGT_TP_CD}" Value="USER">
                                                                <Setter Property="Foreground" Value="#10B981"/>
                                                            </DataTrigger>

                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock Text="  "/>
                                            <Button Grid.Column="1" CommandParameter="{Binding}" Style="{StaticResource TitleButton}"
                                                    Click="TodayTaskTitleButton_Click">
                                                <TextBlock Text="{Binding TASK_TITLE}" TextTrimming="CharacterEllipsis" />
                                            </Button>
                                        </StackPanel>
                                        <!--<TextBlock Margin="0,2,0,0" FontSize="11" Foreground="#EF4444" Text="{Binding OverdueText}" Visibility="{Binding OverdueVisibility}"/>-->

                                    </StackPanel>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Border x:Name="DetailPanel" Grid.Column="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock x:Name="TodayTaskEditorTitleTextBlock" Text="상세 내용" FontSize="16" FontWeight="Bold" Foreground="#0F172A" />
                        <TextBlock Text="업무를 선택하거나 신규 등록 및 수정할 수 있습니다."
                               Margin="0,5,0,12"
                               Foreground="#64748B"
                               TextWrapping="Wrap" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="업무일자" FontWeight="SemiBold"/>
                            <DatePicker Margin="0,5,0,10" SelectedDate="{Binding TASK_DT}"/>
                            <TextBlock Text="대상" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                                <RadioButton Content="공통업무" Margin="0,0,20,0"
                                             IsChecked="{Binding TRGT_TP_CD,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,Converter={StaticResource CodeMatchConverter}, ConverterParameter=ALL}"
                                             Checked="AllTargetRadioButton_Checked"/>
                                <RadioButton Content="개인업무" 
                                             IsChecked="{Binding TRGT_TP_CD,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource CodeMatchConverter}, ConverterParameter=USER}"
                                             Checked="UserTargetRadioButton_Checked"/>

                            </StackPanel>
                            <TextBlock Text="대상 직원" FontWeight="SemiBold"/>

                            <ComboBox x:Name="TargetUserComboBox" Margin="0,5,0,10" 
                                      DisplayMemberPath="STF_NM"
                                      SelectedValuePath="STF_NO" SelectedValue="{Binding TRGT_STF_NO, Mode=TwoWay}"
                                      IsEnabled="False"/>
                            <TextBlock Text="제목" FontWeight="SemiBold" />
                            <TextBox x:Name="TodayTaskTitleInput" Margin="0,5,0,10" Text="{Binding TASK_TITLE, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="내용" FontWeight="SemiBold" />
                            <TextBox x:Name="TodayTaskDetailInput"
                             Margin="0,5,0,12"
                             MinHeight="140"
                             AcceptsReturn="True"
                             TextWrapping="Wrap" Text="{Binding TASK_CONTENT, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Separator Margin="0,10"/>
                            <TextBlock Text="확인 정보" FontWeight="SemiBold"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="상태"/>
                                <TextBlock Grid.Column="1" Text="{Binding CMPL_YN, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="1" Text="확인자" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CMPL_STF_NM}"/>
                                <TextBlock Grid.Row="2" Text="확인일시"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CMPL_DTM}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- 버튼 고정 -->
                    <StackPanel Grid.Row="2">
                        <Button 
                x:Name="SaveTodayTaskButton"
                Content="수정"
                Margin="0,12,0,0"
                Style="{StaticResource PrimaryButton}"
                Click="SaveTodayTaskButton_Click"/>
                        <TextBlock Margin="0,14,0,0" Foreground="#64748B" Text="{Binding LSH_DTM, TargetNullValue=''}"/>
                    </StackPanel>


                </Grid>


            </Border>
        </Grid>
    </Border>
</UserControl>
